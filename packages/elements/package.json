{
  "name": "@kimen/elements",
  "version": "0.0.0",
  "private": true,
  "license": "Apache-2.0",
  "description": "Kimen web components (ki-*). Standards-first Stencil components, tokens-only styling, agent-legible by contract.",
  "type": "module",
  "files": [
    "dist",
    "loader"
  ],
  "scripts": {
    "build": "stencil build",
    "test": "vitest run"
  },
  "nx": {
    "tags": [
      "scope:elements"
    ],
    "implicitDependencies": [
      "@kimen/tokens"
    ]
  },
  "dependencies": {
    "@stencil/core": "4.43.5"
  },
  "devDependencies": {
    "@stencil/vitest": "1.13.3",
    "vitest": "4.1.9"
  },
  "module": "dist/index.js",
  "types": "dist/types/index.d.ts",
  "collection": "dist/collection/collection-manifest.json",
  "collection:main": "dist/collection/index.js",
  "unpkg": "dist/kimen/kimen.esm.js",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.js"
    },
    "./loader": {
      "types": "./loader/index.d.ts",
      "import": "./loader/index.js"
    }
  }
}
