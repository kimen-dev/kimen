{
  "name": "@kimen/elements",
  "version": "0.0.0",
  "private": true,
  "license": "Apache-2.0",
  "description": "Kimen web components (ki-*). Standards-first Stencil components, tokens-only styling, agent-legible by contract.",
  "type": "module",
  "files": [
    "dist",
    "loader"
  ],
  "scripts": {
    "build": "stencil build",
    "test": "vitest run",
    "test-browser": "vitest run --config vitest.browser.config.ts",
    "size": "size-limit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "size-limit": [
    {
      "name": "ki-button marginal cost (component code, runtime excluded), Art. IV single-digit budget",
      "path": "dist/components/ki-button.js",
      "ignore": [
        "@stencil/core"
      ],
      "limit": "9 KB"
    },
    {
      "name": "ki-button worst case (component + full Stencil runtime, first component on a page)",
      "path": "dist/components/ki-button.js",
      "limit": "25 KB"
    },
    {
      "name": "ki-select + ki-option marginal cost (component code, runtime excluded), Art. IV single-digit budget",
      "path": [
        "dist/components/ki-select.js",
        "dist/components/ki-option.js"
      ],
      "ignore": [
        "@stencil/core"
      ],
      "limit": "9 KB"
    },
    {
      "name": "ki-select + ki-option worst case (component pair + full Stencil runtime)",
      "path": "dist/components/ki-select.js",
      "limit": "25 KB"
    }
  ],
  "nx": {
    "tags": [
      "scope:elements"
    ],
    "implicitDependencies": [
      "@kimen/tokens"
    ],
    "targets": {
      "build": {
        "inputs": [
          "default",
          "^default",
          "!{projectRoot}/generated/**"
        ]
      },
      "storybook": {
        "dependsOn": [
          "build"
        ],
        "cache": false
      },
      "build-storybook": {
        "dependsOn": [
          "build"
        ],
        "cache": false
      }
    }
  },
  "dependencies": {
    "@stencil/core": "4.43.5"
  },
  "devDependencies": {
    "@kimen/tokens": "workspace:*",
    "@size-limit/preset-small-lib": "12.1.0",
    "@stencil/storybook-plugin": "0.7.0",
    "@stencil/vitest": "1.13.3",
    "@storybook/addon-a11y": "10.4.6",
    "@storybook/addon-docs": "10.4.6",
    "@vitest/browser-playwright": "4.1.9",
    "axe-core": "4.12.1",
    "playwright": "1.61.1",
    "size-limit": "12.1.0",
    "storybook": "10.4.6",
    "vitest": "4.1.9"
  },
  "module": "dist/index.js",
  "types": "dist/types/index.d.ts",
  "collection": "dist/collection/collection-manifest.json",
  "collection:main": "dist/collection/index.js",
  "unpkg": "dist/kimen/kimen.esm.js",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.js"
    },
    "./loader": {
      "types": "./loader/index.d.ts",
      "import": "./loader/index.js"
    }
  }
}
