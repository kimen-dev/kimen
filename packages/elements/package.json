{
  "name": "@kimen/elements",
  "version": "0.0.0",
  "private": true,
  "license": "Apache-2.0",
  "description": "Kimen web components (ki-*). Standards-first Stencil components, tokens-only styling, agent-legible by contract.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kimen-dev/kimen.git",
    "directory": "packages/elements"
  },
  "files": [
    "dist",
    "loader",
    "generated/custom-elements.json",
    "llms.txt"
  ],
  "scripts": {
    "build": "stencil build && node scripts/sync-components.mjs && node scripts/build-surfaces.mjs",
    "test": "vitest run && vitest run --config vitest.node.config.ts",
    "test-browser": "vitest run --config vitest.browser.config.ts",
    "size": "node scripts/run-size-limit.mjs",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "nx": {
    "tags": [
      "scope:elements"
    ],
    "implicitDependencies": [
      "@kimen/tokens"
    ],
    "targets": {
      "build": {
        "inputs": [
          "default",
          "^default",
          "!{projectRoot}/generated/**",
          "!{projectRoot}/loader/**",
          "!{projectRoot}/llms.txt"
        ],
        "outputs": [
          "{projectRoot}/dist",
          "{projectRoot}/generated",
          "{projectRoot}/loader",
          "{projectRoot}/llms.txt",
          "{workspaceRoot}/llms.txt"
        ]
      },
      "storybook": {
        "dependsOn": [
          "build"
        ],
        "cache": false
      },
      "build-storybook": {
        "dependsOn": [
          "build"
        ],
        "cache": false
      }
    }
  },
  "dependencies": {
    "@stencil/core": "4.43.5"
  },
  "devDependencies": {
    "@kimen/tokens": "workspace:*",
    "@size-limit/preset-small-lib": "12.1.0",
    "@stencil/storybook-plugin": "0.7.0",
    "@stencil/vitest": "1.13.3",
    "@storybook/addon-a11y": "10.4.6",
    "@storybook/addon-docs": "10.4.6",
    "@vitest/browser-playwright": "4.1.9",
    "axe-core": "4.12.1",
    "playwright": "1.61.1",
    "size-limit": "12.1.0",
    "storybook": "10.4.6",
    "vitest": "4.1.9"
  },
  "module": "dist/index.js",
  "types": "dist/types/index.d.ts",
  "customElements": "generated/custom-elements.json",
  "collection": "dist/collection/collection-manifest.json",
  "collection:main": "dist/collection/index.js",
  "unpkg": "dist/kimen/kimen.esm.js",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.js"
    },
    "./loader": {
      "types": "./loader/index.d.ts",
      "import": "./loader/index.js"
    },
    "./ki-*": {
      "types": "./dist/components/ki-*.d.ts",
      "import": "./dist/components/ki-*.js"
    }
  }
}
