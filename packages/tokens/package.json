{
  "name": "@kimen/tokens",
  "version": "0.0.0",
  "private": true,
  "license": "Apache-2.0",
  "description": "Kimen design tokens (DTCG) compiled to CSS custom properties. Primitive → theme → semantic layers; onmars is the default theme (light + dark).",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kimen-dev/kimen.git",
    "directory": "packages/tokens"
  },
  "files": [
    "dist"
  ],
  "exports": {
    "./css": "./dist/css/tokens.css",
    "./css/material3": "./dist/css/tokens.material3.css"
  },
  "scripts": {
    "build": "node ./build.mjs",
    "contrast": "node ./scripts/check-contrast.mjs",
    "size": "size-limit",
    "test": "node --test scripts/*.test.mjs"
  },
  "size-limit": [
    {
      "name": "onmars tokens stylesheet",
      "path": "dist/css/tokens.css",
      "limit": "10 KB"
    },
    {
      "name": "material3 tokens stylesheet",
      "path": "dist/css/tokens.material3.css",
      "limit": "10 KB"
    }
  ],
  "nx": {
    "tags": [
      "scope:tokens"
    ]
  },
  "devDependencies": {
    "@size-limit/preset-small-lib": "12.1.0",
    "size-limit": "12.1.0"
  }
}
