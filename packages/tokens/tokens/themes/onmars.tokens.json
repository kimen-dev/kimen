      "size": {
        "$type": "dimension",
        "caption-1": { "$value": "0.625rem" },
        "overline": { "$value": "0.6875rem" },
        "caption-2": { "$value": "0.75rem" },
        "body-1": { "$value": "0.8125rem" },
        "body-2": { "$value": "0.9375rem" },
        "title-1": { "$value": "0.9375rem" },
        "title-2": { "$value": "1.125rem" },
        "heading-1": { "$value": "1.375rem" },
        "heading-2": { "$value": "1.5625rem" },
        "heading-3": { "$value": "2rem" },
        "heading-4": { "$value": "2.625rem" },
        "heading-5": { "$value": "3.25rem" },
        "heading-6": { "$value": "3.875rem" },
        "display-1": { "$value": "4.75rem" },
        "display-2": { "$value": "5.5rem" },
        "display-3": { "$value": "6.5rem" }
      },
      "line-height": {
        "$type": "dimension",
        "overline": { "$value": "0.75rem" },
        "caption-1": { "$value": "1rem" },
        "caption-2": { "$value": "1rem" },
        "para": { "$value": "1.25rem" },
        "body-1": { "$value": "1.5rem" },
        "body-2": { "$value": "1.5rem" },
        "title-1": { "$value": "1.5rem" },
        "title-2": { "$value": "1.5rem" },
        "heading-1": { "$value": "1.75rem" },
        "heading-2": { "$value": "2.25rem" },
        "heading-3": { "$value": "2.5rem" },
        "heading-4": { "$value": "3rem" },
        "heading-5": { "$value": "3.5rem" },
        "heading-6": { "$value": "4.25rem" },
        "display-1": { "$value": "5rem" },
        "display-2": { "$value": "5rem" },
        "display-3": { "$value": "6rem" }
      },
      "weight": {
        "$type": "fontWeight",
        "display": {
          "normal": { "$value": 400 },
          "medium": { "$value": 500 },
          "semibold": { "$value": 600 },
          "bold": { "$value": 700 }
        },
        "body": {
          "normal": { "$value": 500 },
          "medium": { "$value": 600 },
          "semibold": { "$value": 700 },
          "bold": { "$value": 800 }
        }
      },
      "letter-spacing": {
        "$type": "dimension",
        "$description": "Figma stores these as percentages; compiled to em.",
        "none": { "$value": "0em" },
        "spaced-out": { "$value": "0.02em" },
        "xs": { "$value": "-0.01em" },
        "sm": { "$value": "-0.03em" },
        "md": { "$value": "-0.05em" },
        "lg": { "$value": "-0.07em" }
      }
