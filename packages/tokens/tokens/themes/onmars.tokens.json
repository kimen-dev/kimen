        "300": { "$value": "#b59cd8" },
        "400": { "$value": "#9873c9" },
        "500": { "$value": "#845abe" },
        "500-alpha-1": { "$value": "#845abe1f" },
        "500-alpha-2": { "$value": "#845abe33" },
        "500-alpha-3": { "$value": "#845abe3d" },
        "500-alpha-4": { "$value": "#845abe66" },
        "500-alpha-5": { "$value": "#845abe8f" },
        "600": { "$value": "#5f3993" },
        "700": { "$value": "#472b6e" },
        "800": { "$value": "#2f1d49" },
        "900": { "$value": "#1f1331" },
        "950": { "$value": "#170e25" },
        "high-em": { "$value": "{ki.color.gray.950}" },
