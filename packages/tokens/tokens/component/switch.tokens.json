          },
          "thumb": {
            "$value": "{ki.text.primary-on-primary}"
          },
          "border": {
            "$value": "{ki.outline.none}"
          }
        },
        "disabled": {
          "track": {
            "$value": "{ki.surface.disabled-low-em}"
          },
          "thumb": {
            "$value": "{ki.surface.disabled-high-em}"
          },
          "border": {
