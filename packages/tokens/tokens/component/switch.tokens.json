          },
          "thumb": {
            "$value": "{ki.text.high-em}"
          },
          "border": {
            "$value": "{ki.outline.high-em}"
          }
        },
        "active": {
          "track": {
            "$value": "{ki.surface.s5}"
          },
          "thumb": {
            "$value": "{ki.text.high-em}"
          },
          "border": {
            "$value": "{ki.outline.high-em}"
          }
        },
        "disabled": {
          "track": {
            "$value": "{ki.surface.disabled-low-em}"
          },
          "thumb": {
            "$value": "{ki.surface.disabled-high-em}"
          },
          "border": {
            "$value": "{ki.surface.disabled-med-em}"
          }
        }
      },
      "checked": {
