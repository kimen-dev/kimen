{
  "ki": {
    "tooltip": {
      "radius": {
        "$value": "{ki.radius.sm}"
      },
      "padding-inline": {
        "$value": "{ki.space.md}"
      },
      "padding-block": {
        "$value": "{ki.space.xs}"
      },
      "max-inline-size": {
        "$value": "{ki.space.25xl}"
      },
      "offset": {
        "$value": "{ki.space.xs}"
      },
      "bg": {
        "$value": "{ki.surface.inverse-white}"
      },
      "fg": {
        "$value": "{ki.text.inverse-black}"
      },
      "font-size": {
        "$value": "{ki.font.size.caption-2}"
      },
      "font-weight": {
        "$value": "{ki.font.weight.body.medium}"
      },
      "line-height": {
        "$value": "{ki.font.line-height.caption-2}"
      },
      "shadow": {
        "$value": "0 1px 2px 0 var(--ki-elevation-shadow-dark), 0 2px 6px 2px var(--ki-elevation-shadow-med)"
      },
      "show-delay": {
        "$type": "duration",
        "$value": "500ms"
      },
      "hide-delay": {
        "$type": "duration",
        "$value": "100ms"
      }
    }
  }
}
