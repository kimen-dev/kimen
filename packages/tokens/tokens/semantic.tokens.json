      "control": { "$value": "{ki.radius.md}" }
    },
    "typography": {
      "family": {
        "$type": "fontFamily",
        "base": { "$value": "{ki.font.family.base}" }
      },
      "size": {
        "$type": "dimension",
        "body": { "$value": "{ki.font.size.200}" }
      }
