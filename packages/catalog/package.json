{
  "name": "@kimen/catalog",
  "version": "0.0.0",
  "private": true,
  "license": "Apache-2.0",
  "description": "Kimen neutral catalog and guardrail boundary: schema-constrained specs rendered from a closed component catalog. The durable asset (constitution Art. VIII).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "node scripts/generate-catalog.mjs && tsc -b --pretty false",
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "happy-dom": "20.10.6",
    "vitest": "^4.1.9"
  },
  "nx": {
    "tags": [
      "scope:catalog"
    ],
    "targets": {
      "build": {
        "dependsOn": [
          "^build",
          {
            "projects": [
              "@kimen/elements"
            ],
            "target": "build"
          }
        ],
        "inputs": [
          "{projectRoot}/**/*",
          "!{projectRoot}/src/generated/**",
          "{workspaceRoot}/packages/elements/generated/custom-elements.json",
          "{workspaceRoot}/packages/elements/package.json"
        ],
        "outputs": [
          "{projectRoot}/dist",
          "{projectRoot}/src/generated"
        ]
      }
    }
  },
  "kimenCapabilities": {
    "generatedFrom": "docs/capabilities.json",
    "marker": {
      "start": "kimen:capabilities:catalog-package-status:start",
      "end": "kimen:capabilities:catalog-package-status:end"
    },
    "claims": [
      {
        "id": "guarded-renderer",
        "state": "available",
        "text": "Schema-constrained guarded renderer: untrusted UI specs render only through the neutral catalog, fail-closed"
      },
      {
        "id": "mutation-quality-gate",
        "state": "hardening",
        "text": "Changed-core mutation quality gate in hardening"
      },
      {
        "id": "protocol-adapter-a2ui",
        "state": "available",
        "text": "A2UI protocol adapter: declarative A2UI messages render through the guarded renderer"
      },
      {
        "id": "protocol-adapter-mcp-apps",
        "state": "available",
        "text": "MCP Apps adapter: Kimen surfaces reach MCP Apps hosts as self-contained ui:// resources rendered through the guarded renderer"
      },
      {
        "id": "protocol-adapters-remaining",
        "state": "planned",
        "text": "AG-UI and json-render protocol adapters planned"
      },
      {
        "id": "runtime-catalog",
        "state": "available",
        "text": "Neutral runtime component catalog with schema-validated UI specs at the GenUI boundary"
      },
      {
        "id": "web-components-foundation",
        "state": "available",
        "text": "Machine-readable Web Components foundation with token-driven theming"
      }
    ]
  }
}
