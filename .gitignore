# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
build/
out/
*.tsbuildinfo
# EXCEPTION (Art. I, review round 1): the compiled token CSS is the public
# token contract — committed and diffable; kept in sync by the tokens-sync gate.
!packages/tokens/dist/
packages/tokens/dist/*
!packages/tokens/dist/css/

# Stencil build artifacts (generated/docs.json IS committed, Art. I)
packages/elements/loader/
packages/elements/www/
.stencil/

# Storybook build output and logs
storybook-static/
*storybook.log

# Nx
.nx/cache
.nx/workspace-data
.nx/graph.json

# Test artifacts
coverage/
.stryker-tmp/
reports/
playwright-report/
test-results/

# Spec Kit run state (local, per-run)
.specify/workflows/runs/

# Internal operational docs (founder machines only, never committed)
internal/

# Environment and secrets (never committed, Art. XI)
.env
.env.*
*.pem
*.key

# OS / editor noise
.DS_Store
Thumbs.db
*.log
.idea/
.vscode/*
!.vscode/extensions.json

# Review packets are working artifacts assembled per round, never committed
specs/*/review-packet/
