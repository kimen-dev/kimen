# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
build/
out/
*.tsbuildinfo
# EXCEPTION (Art. I, review round 1): the compiled token CSS is the public
# token contract — committed and diffable; kept in sync by the tokens-sync gate.
!packages/tokens/dist/
packages/tokens/dist/*
!packages/tokens/dist/css/

# Stencil build artifacts (generated/docs.json IS committed, Art. I)
packages/elements/loader/
packages/elements/www/
.stencil/

# Storybook build output and logs
storybook-static/
*storybook.log

# Assembled public site (built by scripts/build-site.sh in CI)
site-dist/

# Nx
.nx/cache
.nx/workspace-data
.nx/graph.json

# Test artifacts
coverage/
.stryker-tmp/
reports/
playwright-report/
test-results/
# Visual regression (Art. X): the CI-generated linux baselines are the only
# versioned arbiters. Local darwin baselines are a personal safety net and
# failed-comparison attachments (actual/diff PNGs) are run artifacts.
packages/elements/browser-tests/__screenshots__/**/*-darwin.png
packages/elements/.vitest-attachments/
# Generated actuals belong to infrastructure fixtures, never to traceability.
scripts/tests/fixtures/output/

# Spec Kit run state (local, per-run)
.specify/workflows/runs/

# Ordinary unattended-attempt state stays local. The host finalizer may retain
# only one validated `.kimen/attempts/<attempt-id>.json` via an exact `git add
# -f -- <path>`; there is deliberately no broad negation here.
.kimen/attempts/

# Internal operational docs (founder machines only, never committed)
internal/

# Environment and secrets (never committed, Art. XI)
.env
.env.*
*.pem
*.key

# OS / editor noise
.DS_Store
Thumbs.db
*.log
.idea/
.vscode/*
!.vscode/extensions.json
