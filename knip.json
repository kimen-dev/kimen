{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignore": ["**/dist/**", "**/generated/**", ".specify/**", ".claude/**"],
  "ignoreDependencies": ["husky", "nx", "@kimen/nx-plugin"],
  "workspaces": {
    ".": {
      "entry": ["scripts/**/*.mjs", "*.config.{ts,mjs}"],
      "project": ["scripts/**/*.mjs", "*.config.{ts,mjs}"],
      "ignoreDependencies": ["@arethetypeswrong/cli", "@stryker-mutator/vitest-runner", "publint"],
      "stencil": false
    },
    "packages/*": {
      "entry": [
        "src/index.ts",
        "*.config.{ts,mjs}",
        "vitest.setup.mjs",
        "size-limit/**/*.{ts,tsx}"
      ],
      "project": ["**/*.{ts,tsx,mjs}", "!**/*.d.ts"],
      "stencil": false
    },
    "packages/kimen": {
      "entry": ["index.mjs"],
      "project": ["**/*.mjs"]
    },
    "tools/*": {
      "entry": ["src/generators/*/generator.js"],
      "project": ["**/*.js"]
    }
  }
}
