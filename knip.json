{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignore": ["**/dist/**", "**/generated/**", ".specify/**", ".claude/**"],
  "ignoreDependencies": ["husky", "nx", "@kimen/nx-plugin"],
  "workspaces": {
    ".": {
      "entry": ["scripts/**/*.mjs"],
      "project": ["scripts/**/*.mjs"]
    },
    "packages/*": {
      "entry": ["src/index.ts", "*.config.{ts,mjs}", "vitest.setup.mjs"],
      "project": ["**/*.{ts,tsx,mjs}", "!**/*.d.ts"]
    },
    "packages/kimen": {
      "entry": ["index.mjs"],
      "project": ["**/*.mjs"]
    },
    "tools/*": {
      "entry": ["src/generators/*/generator.js"],
      "project": ["**/*.js"]
    }
  }
}
