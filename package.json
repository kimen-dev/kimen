{
  "name": "kimen-monorepo",
  "version": "0.0.0",
  "private": true,
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.34.4",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "eslint .",
    "lint:styles": "stylelint \"packages/**/*.css\" \"site/**/*.css\" --allow-empty-input",
    "typecheck": "tsc -b --pretty false && tsc -p packages/elements --noEmit --pretty false && tsc -p packages/elements/browser-tests --pretty false && tsc -p packages/elements/scripts --pretty false",
    "deadcode": "knip",
    "packaging": "bash scripts/gates/cache-env.sh -- node scripts/gates/check-packaging.mjs",
    "test:infra": "node scripts/run-infra-tests.mjs",
    "test:consumer-contract:unit": "bash scripts/gates/cache-env.sh -- node --test scripts/tests/consumer-contract.test.mjs",
    "test:consumer-contract:isolated": "node --test scripts/tests/consumer-contract.test.mjs && node scripts/tests/consumer-contract-real-smoke.mjs",
    "test:consumer-contract": "bash scripts/gates/cache-env.sh -- pnpm run test:consumer-contract:isolated",
    "test:generator-smoke": "node scripts/generator-smoke.mjs",
    "test:generator-contract": "pnpm exec nx run @kimen/nx-plugin:test --skipNxCache",
    "check:tokens": "node scripts/gates/check-tokens.mjs",
    "check:component-inventory": "node scripts/gates/check-component-inventory.mjs",
    "check:packed-manifest": "node scripts/gates/check-packed-manifest.mjs",
    "check:api": "node --test scripts/tests/css-token-surface.test.mjs scripts/tests/public-api.test.mjs scripts/tests/public-api-gate.test.mjs scripts/tests/public-api-snapshot.test.mjs && node scripts/gates/check-public-api.mjs --baseline changes/api/baselines/0.0.0.json --candidate packages/elements/generated/public-api.json --declaration changes/api/005-fase-n-wave2.json",
    "generate:capabilities": "node scripts/gates/check-capabilities.mjs --generate",
    "check:capabilities": "node scripts/gates/check-capabilities.mjs --static-only",
    "test:mutation": "bash scripts/gates/run-mutation.sh",
    "test:mutation:full": "bash scripts/gates/run-mutation.sh --scope full-elements",
    "test:sandbox": "bash sandbox/tests/run-local.sh",
    "check:workflows": "node scripts/gates/check-workflows.mjs",
    "gates": "bash scripts/gates/gates-suite.sh",
    "storybook": "nx storybook @kimen/elements",
    "prepare": "husky"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.4",
    "@biomejs/biome": "2.5.2",
    "@commitlint/cli": "21.2.0",
    "@commitlint/config-conventional": "21.2.0",
    "@eslint/js": "10.0.1",
    "@kimen/nx-plugin": "workspace:*",
    "@nx/eslint-plugin": "23.0.1",
    "@stencil/core": "4.43.5",
    "@stencil/vitest": "1.13.3",
    "@stryker-mutator/api": "9.6.1",
    "@stryker-mutator/core": "9.6.1",
    "@stryker-mutator/vitest-runner": "9.6.1",
    "@vitest/coverage-v8": "4.1.9",
    "eslint": "10.6.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "husky": "9.1.7",
    "knip": "6.24.0",
    "lint-staged": "17.0.8",
    "nx": "23.0.1",
    "publint": "0.3.21",
    "style-dictionary": "5.5.0",
    "stylelint": "17.14.0",
    "stylelint-config-standard": "40.0.0",
    "stylelint-declaration-strict-value": "1.11.1",
    "stylelint-use-logical": "2.1.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.1",
    "vitest": "4.1.9"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,json,md,yml,yaml}": [
      "biome format --write --no-errors-on-unmatched"
    ],
    "*.{ts,tsx}": [
      "eslint --fix --no-warn-ignored"
    ],
    "*.css": [
      "stylelint --fix --allow-empty-input"
    ]
  },
  "pnpm": {
    "overrides": {
      "qs": "6.15.3"
    }
  },
  "workspaces": [
    "packages/*",
    "tools/*"
  ]
}
