{
  "$schema": "https://biomejs.dev/schemas/2.5.2/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": false
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "all",
      "semicolons": "always"
    }
  },
  "files": {
    "includes": [
      "**",
      "!**/dist/**",
      "!**/node_modules/**",
      "!**/.pnpm-store/**",
      "!**/.nx/**",
      "!**/*.md",
      "!pnpm-lock.yaml",
      "!.specify/**",
      "!.claude/**",
      "!packages/elements/src/components.d.ts",
      "!packages/elements/generated/**",
      "!packages/tokens/dist/**",
      "!nx.json"
    ]
  }
}
