{
  "name": "kimen-protected-main",
  "target": "branch",
  "enforcement": "disabled",
  "bypass_actors": [
    {
      "actor_id": 1,
      "actor_type": "Team",
      "bypass_mode": "pull_request"
    }
  ],
  "conditions": {
    "ref_name": {
      "include": ["refs/heads/main"],
      "exclude": []
    }
  },
  "rules": [
    { "type": "deletion" },
    { "type": "non_fast_forward" },
    { "type": "required_linear_history" },
    {
      "type": "pull_request",
      "parameters": {
        "allowed_merge_methods": ["squash"],
        "dismiss_stale_reviews_on_push": true,
        "require_code_owner_review": false,
        "require_last_push_approval": false,
        "required_approving_review_count": 0,
        "required_review_thread_resolution": true
      }
    },
    {
      "type": "required_status_checks",
      "parameters": {
        "do_not_enforce_on_create": false,
        "required_status_checks": [
          { "context": "ci / gates", "integration_id": 1 },
          { "context": "ci / mutation", "integration_id": 1 },
          { "context": "ci / containment", "integration_id": 1 },
          { "context": "codeql / analyze", "integration_id": 1 },
          { "context": "security / semgrep", "integration_id": 1 },
          { "context": "security / osv-scan", "integration_id": 1 },
          { "context": "security / dependency-review", "integration_id": 1 },
          { "context": "security / secrets", "integration_id": 1 },
          { "context": "Socket / scan", "integration_id": 1 }
        ],
        "strict_required_status_checks_policy": true
      }
    }
  ]
}
